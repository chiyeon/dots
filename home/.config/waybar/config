{
   // -------------------------------------------------------------------------
   // Global configuration
   // -------------------------------------------------------------------------

   "layer": "top",

      "position": "top",

      "height": 20,

      "margin-left": 0,
      "margin-bottom": 0,
      "margin-top": 0,
      "margin-right": 0,

      "spacing": 4, // Gaps between modules (4px)

      "modules-left": [
         "hyprland/workspaces",
         //"custom/rofi",
         //"hyprland/submap",
         //"temperature",
         //"idle_inhibitor",
         //"mpd"
         "custom/spotify"
      ],
      "modules-center": [
         //"hyprland/window"
         "clock#date"
         //"custom/weather"
         //"custom/gammastep"
      ],
      "modules-right": [
         //"custom/storage",
         "temperature",
         "memory",
         //"cpu",
         //"pulseaudio",
         "backlight",
         "wireplumber",
         //"custom/screenshot_t",
         "battery",
         "tray"
         /*"custom/power"*/
      ],


      // -------------------------------------------------------------------------
      // Modules
      // -------------------------------------------------------------------------

      "custom/sp1": {
         "format": " | ",
         "tooltip": false
      },
      "custom/sp2": {
         "format": " |",
         "tooltip": false
      },


      "custom/rofi": {
         "format": "’āē",
         "tooltip": false,
         "on-click-right": "nwg-drawer",
         "on-click": "wofi --show run",
         "on-click-middle": "pkill -9 wofi"
      },
      "custom/screenshot_t":{
         "format":"’Ć░ ",
         "on-click": "flameshot gui"
            //"on-click": "~/.config/hypr/scripts/screenshot_full",
            //"on-click-right":"~/.config/hypr/scripts/screenshot_area"
      },

      "clock#1": {
         "format": "’ü│ {:%a}",
         "tooltip": false,
         "on-click": "gsimplecal"
      },
      "clock#2": {
         "format": "’ē┤ {:%d-%h-%Y}",
         "tooltip": false,
         "on-click": "gsimplecal"
      },
      "clock#3": {
         "format": "’ĆŚ {:%H:%M:%S %p}",
         "tooltip": false,
         "on-click": "gsimplecal"
      },

      "temperature": {
         // "thermal-zone": 1,
         "interval": 4,
         //"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
         "critical-threshold": 90,
         // "format-critical": "’ŗē {temperatureC}┬░C",
         "format-critical": "’ü▒  {temperatureC}┬░C",
         //"format": "{icon}  {temperatureC}┬░C",
         "format": "’ŗē  {temperatureC}┬░C",
         //"format-icons": ["’Ø½", "’ŗē", "’Ø®"],
         "max-length": 7,
         "min-length": 7,
         "on-click": "xsensors"
      },

      "memory": {
         "interval": 30,
         "format": "’ŗø   {used:0.2f} GB",
         //"format": "’ŗø  {used:0.2f} / {total:0.0f} GB",
         "on-click": "alacritty -e btop"
      },

      "battery": {
         "interval": 2,
         "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
         },
         "format": "{icon}    {capacity}%",
         "format-charging": "’¢ā    {capacity}%",
         "format-plugged": "’ć”    {capacity}%",
         "format-icons": [
            "’ēä",
         "’ēā",
         "’ēé",
         "’ēü",
         "’ēĆ"
         ]
      },
      "network": {
         "format-wifi": "’ć½ {essid} ({signalStrength}%)",
         "format-ethernet": "{ifname}: {ipaddr}/{cidr} ’×¢",
         "format-linked": "{ifname} (No IP) ’×¢",
         "format": "’ĆÆ",
         "format-disconnected": "’Üö",
         "format-alt": "{ifname}: {ipaddr}/{cidr}",
         "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
         "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
         "tooltip-format": "’éō {bandwidthUpBits} ’ĆÖ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
         "tooltip-format-wifi": "’ć½ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\n’éō {bandwidthUpBits} ’ĆÖ {bandwidthDownBits}",
         "interval": 10
      },
      "custom/storage": {
         "format": "’éĀ {}",
         "format-alt": "{percentage}% ’éĀ",
         "format-alt-click": "click-right",
         "return-type": "json",
         "interval": 60,
         "exec": "~/.config/waybar/modules/storage.sh"
      },

      "backlight": {
         "device": "intel_backlight",
         "format": "{icon}    {percent}%",
         "format-alt": "{percent}% {icon}",
         "format-alt-click": "click-right",
         //"format-icons": ["’ā½", "’Ā┤"],
         "format-icons": ["’åģ", "’äæ"],
         "on-scroll-down": "brightnessctl s 5%-",
         "on-scroll-up": "brightnessctl s +5%"
      },
      "idle_inhibitor": {
         "format": "{icon}",
         "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
         },
         "tooltip": "true"
      },
      "custom/weather": {
         "format": "{}",
         "format-alt": "{alt}: {}",
         "format-alt-click": "click-right",
         "interval": 3600,
         "exec": "curl -s 'https://wttr.in/?format=1'",
         //"return-type": "json",
         //"exec": "~/.config/waybar/modules/weather.sh",
         "exec-if": "ping wttr.in -c1"
      },
      "custom/pacman": {
         "format": "<big>¶Åå▓</big>  {}",
         "interval": 3600,                     // every hour
         "exec": "checkupdates | wc -l",       // # of updates
         "exec-if": "exit 0",                  // always run; consider advanced run conditions
         "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
         "signal": 8,
         "max-length": 5,
         "min-length": 3
      },

      "custom/spotify": {
         "exec": "~/.config/waybar/mediaplayer.py --player spotify",
         "format": "{}  ’å╝",
         "return-type": "json",
         "on-click": "playerctl play-pause",
         "on-scroll-up": "playerctl next",
         "on-scroll-down": "playerctl previous"
      },

      "custom/media": {
         "format": "{0} {1}",
         "return-type": "json",
         "max-length": 40,
         "format-icons": {
            "spotify": "’å╝",
            "default": "­¤Ä£"
         },
         "escape": true,
         //"exec": "~/.config/waybar/mediaplayer.py" // Script in resources folder
         // "exec": "~/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
      },

      "custom/power": {
         "format": " ¾░Éź ",
         "tooltip": false,
         "on-click": "wlogout"
      },

      "clock": {
         "format": "’ĆŚ  {:%H:%M  ’ü│ %e %b}",
         "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
         "today-format": "<b>{}</b>"
      },

      "clock#date": {
         "format": "¾░źö   {:%I:%M %p         ’ü│   %e %b}",
         //"format": "¾░źö  {:%H:%M\t ’ü│ %e %b}",
         "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
         "today-format": "<b>{}</b>"
      },

      "custom/gammastep": {
         "interval": 5,
         "return-type": "json",
         "exec": {
            "pre": "if unit_status=\"$(systemctl --user is-active gammastep)\"; then\nstatus=\"$unit_status ($(journalctl --user -u gammastep.service -g 'Period: ' | tail -1 | cut -d ':' -f6 | xargs))\"\nelse\nstatus=\"$unit_status\"\nfi",
            "alt": "${status:-inactive}",
            "tooltip": "Gammastep is $status",
         },
         "format": "{icon}",
         "format-icons": {
            "activating": "¾░ü¬ ",
            "deactivating": "¾░ü¬ ",
            "inactive": "? ",
            "active (Night)": "’åå ",
            "active (Nighttime)": "’åå ",
            "active (Transition (Night)": "’åå ",
            "active (Transition (Nighttime)": "’åå ",
            "active (Day)": "ŅīŹ ",
            "active (Daytime)": "ŅīŹ ",
            "active (Transition (Day)": "ŅīŹ ",
            "active (Transition (Daytime)": "ŅīŹ ",
         },
         "on-click": "systemctl --user is-active gammastep && systemctl --user stop gammastep || systemctl --user start gammastep",
      },

      "cpu": {
         "interval": 1,
         //"format": "’ŗø {}%", // Icon: microchip
         "format": "{max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
         "max-length": 13,
         "min-length": 13
      },

      "mpd": {
         "max-length": 25,
         "format": "<span foreground='#bb9af7'>’Ćü</span> {title}",
         "format-paused": "’Ćü {title}",
         "format-stopped": "<span foreground='#bb9af7'>’Ćü</span>",
         "format-disconnected": "",
         "on-click": "mpc --quiet toggle",
         "on-click-right": "mpc update; mpc ls | mpc add",
         "on-click-middle": "alacritty -e ncmpcpp",
         "on-scroll-up": "mpc --quiet prev",
         "on-scroll-down": "mpc --quiet next",
         "smooth-scrolling-threshold": 5,
         "tooltip-format": "{title} - {artist} ({elapsedTime:%M:%S}/{totalTime:%H:%M:%S})"
      },

      "custom/title": {
         "format": "{}",
         "interval": 0,
         "return-type": "json",
         //"max-length": 35,
         "tooltip": false
      },

      "custom/title#name": {
         "format": "{}",
         "interval": 0,
         "return-type": "json",

         "max-length": 35,
         "exec": "$HOME/.scripts/title"
      },

      /*"custom/keyboard": {
        "format": "’ä£ {}",
        "interval": 1,
        "exec": "$HOME/.config/waybar/get_kbdlayout.sh"
        },*/

      "hyprland/workspaces": {
         "all-outputs": true,
         "format": "{icon}",
         "format-icons": {
            "1": "’æä ",
            "2": "’æä ",
            "3": "’æä ",
            "4": "’æä ",
            "5": "’æä ",
            "6": "’æä ",
            "7": "’æä ",
            "8": "’æä ",
            "9": "’æä ",
            "10": "’æä ",
         },
         "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
         "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
         "sort-by-number": true,
         "active-only": false,
      },

      "hyprland/window": {
         "max-length": 100,
         "separate-outputs": true
      },

      "pulseaudio": {
         "scroll-step": 3, // %, can be a float
         "format": "{icon} {volume}% {format_source}",
         "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
         "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
         "format-muted": "’Ü® {format_source}",
         //"format-source": "{volume}% ’ä░",
         //"format-source-muted": "’ä▒",
         "format-source": "’ä░",
         "format-source-muted": "’ä▒",
         "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
         },
         "on-click": "pavucontrol",
         "on-click-right": "amixer sset Master toggle"
      },

      "wireplumber": {
         "on-click": "pavucontrol",
         "on-click-right": "amixer sset Master toggle 1>/dev/null",
         //on-click: "${wpctl} set-mute @DEFAULT_AUDIO_SINK@ toggle";
         //on-scroll-down: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04+";
         //on-scroll-up: "${wpctl} set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 0.04-";
         "format": "<span foreground='#fab387'>{icon}</span>  {volume}%",
         "format-muted": "’Ü® ",
         "format-source": "’ä░",
         "format-source-muted": "’ä▒",
         //"format-muted": "<span foreground='#fab387'>’æ” </span>",
         //"format-icons": [ "<span foreground='#fab387'>’Ć©</span>" ]
         "format-icons": {
            "headphone": "’Ćź ",
            "hands-free": "’¢É ",
            "headset": "’¢É ",
            "phone": "’éĢ ",
            "portable": "’éĢ ",
            "car": "’å╣ ",
            "default": ["’Ć” ", "’Ć¦ ", "’Ć© "]
         },
      },

      "tray": {
         "icon-size": 15,
         "spacing": 8
      }
}
